<div class="cel-editor-wrap">

  {{!-- World basics --}}
  <div class="cel-editor-section">
    <div class="cel-editor-sectionhead">World Settings</div>
    <div class="cel-editor-row">
      <label class="cel-editor-label">World name</label>
      <input name="calName" type="text" value="{{calName}}" class="cel-input cel-input-grow" />
    </div>
    <div class="cel-editor-row">
      <label class="cel-editor-label">Days per year</label>
      <input name="daysPerYear" type="number" value="{{daysPerYear}}" min="1" class="cel-input cel-input-num" />
    </div>
  </div>

  {{!-- Moon list --}}
  <div class="cel-editor-section">
    <div class="cel-editor-sectionhead">Moons</div>
    {{#each moons}}
    <div class="cel-moon-row">
      <div class="cel-moon-row-top">
        <input name="moon-name-{{index}}" type="text" value="{{name}}" placeholder="Moon name" class="cel-input cel-input-grow" />
        <input name="moon-color-{{index}}" type="color" value="{{color}}" class="cel-color-picker" title="Moon color" />
        <button type="button" data-action="remove-moon" data-index="{{index}}" class="cel-icon-btn" title="Remove">✕</button>
      </div>
      <div class="cel-moon-row-bot">
        <label class="cel-sublabel">Orbit days</label>
        <input name="moon-orbit-{{index}}" type="number" value="{{orbitDays}}" min="1" class="cel-input cel-input-num" />
        <label class="cel-sublabel">Size</label>
        <select name="moon-size-{{index}}" class="cel-select">
          <option value="tiny">Tiny</option>
          <option value="small">Small</option>
          <option value="medium">Medium</option>
          <option value="large">Large</option>
        </select>
        <label class="cel-sublabel">Start phase (0–1)</label>
        <input name="moon-start-{{index}}" type="number" value="{{startPhase}}" min="0" max="1" step="0.05" class="cel-input cel-input-num" />
      </div>
    </div>
    {{/each}}
    <button type="button" data-action="add-moon" class="cel-add-btn">+ Add Moon</button>
  </div>

  {{!-- Event effects --}}
  <div class="cel-editor-section">
    <div class="cel-editor-sectionhead">Event Effects</div>
    <div class="cel-editor-hint">One boon or pitfall per line. Leave blank for no effects on this event type.</div>
    {{#each eventTypes}}
    <details class="cel-effect-group">
      <summary class="cel-effect-summary" style="color: {{color}}">{{icon}} {{label}}</summary>
      <div class="cel-effect-body">
        <div class="cel-sublabel">Boons — each line is one bonus for this night</div>
        <textarea name="boons-{{type}}" class="cel-textarea" rows="3" placeholder="e.g. Healing spells restore 1d8 extra hit points">{{boons}}</textarea>
        <div class="cel-sublabel" style="margin-top: 8px">Pitfalls — each line is one hazard</div>
        <textarea name="pitfalls-{{type}}" class="cel-textarea" rows="3" placeholder="e.g. Wild magic surges trigger on a 1–3">{{pitfalls}}</textarea>
      </div>
    </details>
    {{/each}}
  </div>

  {{!-- Footer --}}
  <div class="cel-editor-footer">
    <button type="button" data-action="save" class="cel-save-btn">✓ Save &amp; Apply</button>
    <button type="button" data-action="cancel" class="cel-cancel-btn">Cancel</button>
  </div>

</div>
